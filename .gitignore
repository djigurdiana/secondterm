## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.user
*.users
*.suo
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
[Bb]in/
[Oo]bj/
[Bb]uild/
*.exe
*.dll
*.pdb
*.tmp
*.cache

# Project files
*.csproj
*.fsproj
*.vbproj
*.lib
*.ncb
*.opensdf
*.sdf
*.cache
*.exp

# Miscellaneous
*.pidb
*.log
*.vspscc
*.vssscc
.buildlog
*.hmap
*.vsp
*.mdf
*.ldf
*.ndf

# Visual Studio temporary files
_ReSharper*/
*.resharper
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.scc
*.vsloaded
*.vshost.*
.ionide/
*.sqlite
*.VC.db

# NuGet
*.nuget.props
*.nuget.targets
*.nupkg
*.snupkg
*.lib.metadata
*.lib.format
# The packages folder can be ignored because of Package Restore
[Pp]ackages/
# Windows Azure Subscriptions
*.publishsettings
# Azure Cloud Services
*.cscfg
*.csdef
*.appx
*.appxrec
*.appxbundle
*.azurePublishSettings
*.psess
*.vsko
*.webinfo

# DotNet files
.config/
# Ignore Visual Studio Code files
.vscode/

# Ignore files generated by the .NET command line
project.assets.json
project.nuget.cache
# Directories
artifacts/
